{
  "name": "black-polar",
  "version": "2.0.0",
  "description": "Black Polar — Multi-app Express monorepo",
  "type": "module",
  "private": true,
  "scripts": {
    "main":       "node src/apps/main/server.js",
    "portfolios": "node src/apps/portfolios/server.js",
    "tlm":        "node src/apps/tlm/server.js",
    "dev":        "node --watch src/apps/main/server.js",
    "dev:p":      "node --watch src/apps/portfolios/server.js",
    "dev:t":      "node --watch src/apps/tlm/server.js",
    "css":        "npx tailwindcss -i ./src/shared/styles/global.css -o ./src/shared/styles/output.css --watch",
    "css:build":  "npx tailwindcss -i ./src/shared/styles/global.css -o ./src/shared/styles/output.css --minify"
  },
  "dependencies": {
    "compression":        "^1.7.4",
    "cors":               "^2.8.5",
    "dotenv":             "^16.4.5",
    "ejs":                "^3.1.10",
    "express":            "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "helmet":             "^7.1.0",
    "mongoose":           "^8.4.1",
    "morgan":             "^1.10.0",
    "serve-index":        "^1.9.1"
  },
  "devDependencies": {
    "tailwindcss": "^3.4.4"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
