# Environment
NODE_ENV=development

# App Configuration
APP_NAME=Black Polar
MAIN_PORT=3000
PORTFOLIOS_PORT=4000
TLM_PORT=5000

# MongoDB Configuration (desactivado en producción por defecto)
MONGODB_URI=mongodb://username:password@host:27017/database
# Establecer DISABLE_DB=true para desactivar completamente la BD
DISABLE_DB=false

# CORS Configuration
CORS_ORIGIN=http://localhost:3000,http://localhost:4000

# Rate Limiting (ms y número máximo de requests)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Logging
LOG_LEVEL=debug
