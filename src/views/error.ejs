<!DOCTYPE html>
<html>
<head>
  <title>Error</title>

  <!-- Fuentes -->
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css?family=VT323" rel="stylesheet">

  <style>
    body {
      font-family: 'VT323', monospace;
    }
  </style>
</head>

<body class="bg-[#000] text-[#e0e2f4] text-[20px]">

  <div class="w-[90%] max-w-[640px] mx-auto pt-[10%]">

    <!-- Header tipo BSOD -->
    <div class="text-center text-[#0414a7] mb-12">
      <span class="bg-[#aaaaaa] px-4 py-1">
        Error <%= statusCode %>
      </span>
    </div>

    <!-- Mensaje -->
    <h1 class="text-[1rem] leading-tight mb-6">
      <%= message %>
    </h1>

    <!-- Stack (solo dev) -->
    <% if (stack) { %>
      <pre class="bg-black text-left p-4 overflow-x-auto text-sm mb-6">
<%= stack %>
      </pre>
    <% } %>

    <!-- Navegación -->
    <div class="text-center mt-8">
      <a href="/" 
         class="px-3 py-1 no-underline hover:bg-[#aaaaaa] hover:text-[#0414a7]">
        Volver al inicio
      </a>
    </div>

  </div>

</body>
</html>